# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/compliance_db
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=30
SQL_ECHO=false

# LLM and Embedding Configuration
# v3 signal_extractor selection priority: LM Studio > Azure > OpenAI

# Option 1: LM Studio / Ollama / vLLM / any OpenAI-compatible local endpoint
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_API_KEY=lm-studio          # default, usually unused
# LM_STUDIO_MODEL=local-model          # name shown in LM Studio
# LM_STUDIO_TIMEOUT=60                 # seconds

# Option 2: Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_key_here
# OPENAI_API_VERSION=2024-02-15-preview
# AZURE_DEPLOYMENT_NAME=gpt-4o-mini

# Option 3: Public OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Google Custom Search API (for research agent)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Backend
AI_CASES_RECIPIENT=ServicePortalen@kalundborg.dk
AI_CASES_CC=pavi@kalundborg.dk
AI_CASES_STORE=data/ai_cases.json

# SMTP (værdier skal udfyldes for at sende mails)
SMTP_HOST=smtp.kalundborg.dk
SMTP_PORT=587
SMTP_USER=brugernavn
SMTP_PASSWORD=kodeord
SMTP_USE_TLS=true
SMTP_FROM=no-reply@kalundborg.dk
SMTP_REPLY_TO=ServicePortalen@kalundborg.dk

# Eksempel på frontend/backend base url hvis nødvendigt
# REACT_APP_API_BASE_URL=http://localhost:8000

# Caching Configuration
CACHE_DIR=.cache
CACHE_TTL=3600
ENABLE_CACHING=True

# ---- Server / Deploy ----
# API_HOST=0.0.0.0 binder til alle interfaces så Tailscale virker fra iPhone.
# Sæt til 127.0.0.1 hvis du KUN vil have lokal adgang.
API_HOST=0.0.0.0
API_PORT=8001
# API_RELOAD=true er udviklertilstand (auto-genstart ved kode-ændring).
# scripts/start_backend.sh sætter den til false uanset.
API_RELOAD=true

# Frontend port — bruges af scripts/start_frontend.sh
FRONTEND_PORT=8090

# ---- Observability ----
# TYR_LOG_DIR override default ~/Library/Logs/Tyr/
# TYR_LOG_DIR=/var/log/tyr
LOG_LEVEL=INFO

# ---- GDPR retention (Modul 1) ----
# Hvor længe persondata gemmes før auto-sletning. Bruges af det daglige
# retention-job kl. 02:00. Er en del af DPIA'en — kontakt jurist før ændring.
ASSESSMENT_LOG_RETENTION_DAYS=1825   # 5 år
CASE_RETENTION_DAYS=3650             # 10 år
DOCUMENT_RETENTION_DAYS=1825         # 5 år
RETENTION_ENABLED=true
